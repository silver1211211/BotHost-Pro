APP_NAME="BotHost Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://example.com
APP_PUBLIC_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bot_platform
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
BROADCAST_LIMIT_FREE=20000
BROADCAST_LIMIT_PRO=100000
BROADCAST_LIMIT_BUSINESS=unlimited
BROADCAST_BATCH_SIZE=20
BROADCAST_MESSAGE_DELAY_MS=100
BROADCAST_BATCH_DELAY_SECONDS=1
BROADCAST_IMAGE_MAX_KB=10240

CACHE_STORE=redis
# Legacy Laravel installs may still read CACHE_DRIVER.
# CACHE_DRIVER=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
# Local Redis option:
# docker run --name bothost-redis -p 6379:6379 -d redis:alpine

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="BotHost Pro"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

NODE_RUNTIME_URL=http://127.0.0.1:8787
NODE_RUNTIME_SECRET=

RUNTIME_MODE=local
RUNTIME_DOCKER_ENABLED=false
RUNTIME_DOCKER_IMAGE=bothost-node-runtime
RUNTIME_CONTAINER_PREFIX=bothost-bot
RUNTIME_HTTP_PORT_START=8800
RUNTIME_TIMEOUT_MS=5000
RUNTIME_MEMORY_LIMIT=128m
RUNTIME_CPU_LIMIT=0.25
RUNTIME_NETWORK=bothost-runtime
RUNTIME_KEEP_PAUSED_WARM=false
RUNTIME_AUTO_RESTART=true

OXAPAY_MERCHANT_API_KEY=
OXAPAY_BASE_URL=https://api.oxapay.com
OXAPAY_CALLBACK_SECRET=
OXAPAY_FEE_PAID_BY_USER=true
OXAPAY_ENABLED=true
TEMPLATE_ZIP_MAX_KB=51200
TEMPLATE_IMAGE_MAX_KB=5120
